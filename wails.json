    "frontend:dev:watcher": "pnpm run dev",
    "frontend:dev:serverUrl": "http://localhost:5173",
    "wailsjsdir": "./frontend/src/wailsjs",
    "version": "2",
    "info": {
        "productName": "Chatlog"
    }
}
