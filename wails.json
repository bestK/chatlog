{
    "name": "chatlog",
    "outputfilename": "chatlog",
    "frontend:dir": "frontend",
    "frontend:install": "pnpm install && pnpm --dir ../web install",
    "frontend:build": "pnpm --dir ../web run build && pnpm run build",
